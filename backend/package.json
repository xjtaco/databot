    "marked": "^17.0.5",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "nodemailer": "^8.0.4",
    "openai": "^6.15.0",
    "p-queue": "^9.1.0",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "short-uuid": "^6.0.3",
    "sqlite": "^5.1.1",
