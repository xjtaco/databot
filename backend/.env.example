PORT=3000
NODE_ENV=development
BASE_URL=/api

# Logging Configuration
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_FILES=5
LOG_MAX_SIZE=20m

# LLM Configuration
LLM_TYPE=openai
LLM_API_KEY=your-llm-api-key
LLM_MODEL=model_id
LLM_BASE_URL=https://api.openai.com/v1

# WebSocket Configuration
WS_ENABLED=true
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=30000
WS_MAX_MISSED_HEARTBEATS=3

# Encryption Configuration
# 256-bit key (64 hex characters) for AES-256-GCM encryption of database passwords
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here-must-be-exactly-64chars

# Authentication
JWT_SECRET=your-jwt-secret-key-here
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d
# Set to "false" to allow refresh-token cookies over HTTP (non-HTTPS deployments)
# COOKIE_SECURE=false
ADMIN_INITIAL_PASSWORD=Admin@123
ADMIN_EMAIL=admin@localhost
INTERNAL_PORT=3001