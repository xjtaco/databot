{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss}\"",
    "stylelint": "stylelint \"src/**/*.{scss,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{scss,vue}\" --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preflight": "pnpm run lint:fix && pnpm run lint && pnpm run stylelint:fix && pnpm run stylelint && pnpm run format && pnpm run format:check && pnpm run typecheck && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@element-plus/icons-vue": "^2.3.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "axios": "^1.13.4",
    "codemirror": "^6.0.2",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.3.1",
    "element-plus": "^2.9.7",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.577.0",
    "marked": "^15.0.7",
    "pinia": "^2.3.1",
    "plotly.js-dist-min": "^3.4.0",
    "sql-formatter": "^15.7.3",
    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.6.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^17.1.0",
    "jsdom": "^26.1.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.5.3",
    "sass": "^1.89.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.0",
    "unplugin-auto-import": "^19.2.0",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.10"
  }
}
